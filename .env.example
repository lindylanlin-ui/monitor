# 時區，會套用到容器內部的時間顯示。
TZ=Asia/Taipei

# 各服務映像版本。固定版本可讓不同主機部署結果一致。
PROMETHEUS_VERSION=v3.12.0
GRAFANA_VERSION=13.0.2
NODE_EXPORTER_VERSION=v1.11.1
CADVISOR_VERSION=0.57.0
BLACKBOX_EXPORTER_VERSION=v0.28.0
SNMP_EXPORTER_VERSION=v0.30.1

# cAdvisor 需要讀取 Docker 真實資料目錄。
# 一般 apt 安裝常見為 /var/lib/docker
# snap 安裝常見為 /var/snap/docker/common/var-lib-docker
DOCKER_ROOT_DIR=/var/lib/docker

# 對外開放的連接埠。若主機已有衝突，可在本機自行調整。
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Prometheus 保存天數與外部 URL。
# 如果之後放到反向代理後面，請把 URL 改成實際對外網址。
PROMETHEUS_RETENTION=30d
PROMETHEUS_EXTERNAL_URL=http://localhost:9090
GRAFANA_ROOT_URL=http://localhost:3000

# Grafana 初始管理員帳密。
# 請在正式使用前改掉預設密碼，並避免把真實密碼提交到 Git。
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-now
