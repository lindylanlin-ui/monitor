        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "avg by (instance) (hrProcessorLoad{job=\"snmp\", instance=~\"$device\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP CPU 負載",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "100 * ((memTotalReal{job=\"snmp\", instance=~\"$device\"} - memAvailReal{job=\"snmp\", instance=~\"$device\"} - memCached{job=\"snmp\", instance=~\"$device\"} - memBuffer{job=\"snmp\", instance=~\"$device\"}) / memTotalReal{job=\"snmp\", instance=~\"$device\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP 記憶體使用率",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(ifHCInOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} in",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(ifHCOutOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} out",
          "refId": "B"
        }
      ],
      "title": "SNMP 網路吞吐量",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "laLoadFloat{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{laNames}}",
          "refId": "A"
        }
      ],
      "title": "平均負載",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "temperature{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} system",
          "refId": "A"
        },
        {
          "expr": "diskTemperature{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{diskID}}",
          "refId": "B"
        }
      ],
      "title": "Synology 溫度",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "storageIOLA{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{storageIODevice}}",
          "refId": "A"
        }
      ],
      "title": "Synology 儲存負載",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "100 * (hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} / hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"})",
          "legendFormat": "{{instance}} {{hrStorageDescr}}",
          "refId": "A"
        }
      ],
      "title": "Synology 儲存空間使用率",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*使用率"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 9,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "100 * (hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} / hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"})",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 使用率",
          "refId": "A"
        },
        {
          "expr": "(hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} * hrStorageAllocationUnits{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) / 1073741824",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 已用",
          "refId": "B"
        },
        {
          "expr": "((hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} - hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) * hrStorageAllocationUnits{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) / 1073741824",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 可用",
          "refId": "C"
        },
        {
          "expr": "(hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} * hrStorageAllocationUnits{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) / 1073741824",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 總容量",
          "refId": "D"
        }
      ],
      "title": "Synology 容量摘要",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "1": {
                        "color": "green",
                        "index": 0,
                        "text": "正常"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "from": null,
                      "result": {
                        "color": "red",
                        "index": 1,
                        "text": "異常"
                      },
                      "to": 0.999999
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 1.000001,
                      "result": {
                        "color": "red",
                        "index": 2,
                        "text": "異常"
                      },
                      "to": null
                    },
                    "type": "range"
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 1.000001
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 7,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "diskHealthStatus{job=\"snmp\", instance=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "Value": 0,
              "Time": 1,
              "__name__": 2,
              "device": 3,
              "diskID": 4,
              "instance": 5,
              "job": 6,
              "role": 7,
              "site": 8,
              "snmp_auth": 9,
              "snmp_module": 10
            },
            "renameByName": {}
          }
        }
      ],
      "title": "Synology 磁碟健康狀態",
      "type": "table"
    }
  ],
  "refresh": "30s",
