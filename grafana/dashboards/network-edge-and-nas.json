      "targets": [
        {
          "expr": "avg by (instance) (hrProcessorLoad{job=\"snmp\", instance=~\"$device\"})",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP CPU 負載",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * ((memTotalReal{job=\"snmp\", instance=~\"$device\"} - memAvailReal{job=\"snmp\", instance=~\"$device\"} - memCached{job=\"snmp\", instance=~\"$device\"} - memBuffer{job=\"snmp\", instance=~\"$device\"}) / memTotalReal{job=\"snmp\", instance=~\"$device\"})",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP 記憶體使用率",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(ifHCInOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} in",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(ifHCOutOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} out",
          "refId": "B"
