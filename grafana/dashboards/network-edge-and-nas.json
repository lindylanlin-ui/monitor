  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "avg by (instance) (hrProcessorLoad{job=\"snmp\", instance=~\"$device\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP CPU Load",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - (memAvailReal{job=\"snmp\", instance=~\"$device\"} / memTotalReal{job=\"snmp\", instance=~\"$device\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "SNMP Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(ifHCInOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} in",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(ifHCOutOctets{job=\"snmp\", instance=~\"$device\"}[5m]) * 8)",
          "legendFormat": "{{instance}} out",
          "refId": "B"
        }
      ],
      "title": "SNMP Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "laLoadFloat{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{laNames}}",
          "refId": "A"
        }
      ],
      "title": "Load Average",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "temperature{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} system",
          "refId": "A"
        },
        {
          "expr": "diskTemperature{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{diskID}}",
          "refId": "B"
        }
      ],
      "title": "Synology Temperature",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "storageIOLA{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{storageIODevice}}",
          "refId": "A"
        }
      ],
      "title": "Synology Storage Load",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "1": {
                        "color": "green",
                        "index": 0,
                        "text": "正常"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "from": null,
                      "result": {
                        "color": "red",
                        "index": 1,
                        "text": "異常"
                      },
                      "to": 0.999999
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 1.000001,
                      "result": {
                        "color": "red",
                        "index": 2,
                        "text": "異常"
                      },
                      "to": null
                    },
                    "type": "range"
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 1.000001
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 7,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "diskHealthStatus{job=\"snmp\", instance=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "Value": 0,
              "Time": 1,
              "__name__": 2,
              "device": 3,
              "diskID": 4,
              "instance": 5,
              "job": 6,
              "role": 7,
              "site": 8,
              "snmp_auth": 9,
              "snmp_module": 10
            },
            "renameByName": {}
          }
        }
      ],
      "title": "Synology Disk Health",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "monitoring",
    "snmp"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(up{job=\"snmp\"}, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "SNMP Device",
        "multi": false,
        "name": "device",
        "options": [],
        "query": {
          "query": "label_values(up{job=\"snmp\"}, instance)",
          "refId": "Prometheus-snmp"
        },
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
