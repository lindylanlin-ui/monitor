    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "storageIOLA{job=\"snmp\", instance=~\"$device\"}",
          "legendFormat": "{{instance}} {{storageIODevice}}",
          "refId": "A"
        }
      ],
      "title": "Synology 儲存負載",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "100 * (hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} / hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"})",
          "legendFormat": "{{instance}} {{hrStorageDescr}}",
          "refId": "A"
        }
      ],
      "title": "Synology 儲存空間使用率",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*已用"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*可用"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 9,
      "options": {
        "displayLabels": [
          "name",
          "percent",
          "value"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "(hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} * hrStorageAllocationUnits{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) / 1073741824",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 已用",
          "refId": "A"
        },
        {
          "expr": "((hrStorageSize{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"} - hrStorageUsed{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) * hrStorageAllocationUnits{job=\"snmp\", instance=~\"$device\", hrStorageType=\"1.3.6.1.2.1.25.2.1.4\", hrStorageDescr=~\"/volume[0-9]+\"}) / 1073741824",
          "instant": true,
          "legendFormat": "{{instance}} {{hrStorageDescr}} 可用",
          "refId": "B"
        }
      ],
      "title": "Synology 容量摘要",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "1": {
                        "color": "green",
                        "index": 0,
                        "text": "正常"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "from": null,
                      "result": {
                        "color": "red",
                        "index": 1,
                        "text": "異常"
                      },
                      "to": 0.999999
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 1.000001,
                      "result": {
                        "color": "red",
                        "index": 2,
                        "text": "異常"
                      },
                      "to": null
                    },
                    "type": "range"
                  }
                ]
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 1.000001
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 7,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "diskHealthStatus{job=\"snmp\", instance=~\"$device\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "Value": 0,
              "Time": 1,
              "__name__": 2,
              "device": 3,
              "diskID": 4,
              "instance": 5,
              "job": 6,
              "role": 7,
              "site": 8,
              "snmp_auth": 9,
              "snmp_module": 10
            },
            "renameByName": {}
          }
        }
      ],
      "title": "Synology 磁碟健康狀態",
      "type": "table"
    }
