        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "100 * sum(up{job=~\"node-exporter|windows-exporter|snmp\"}) / clamp_min(count(up{job=~\"node-exporter|windows-exporter|snmp\"}), 1)",
